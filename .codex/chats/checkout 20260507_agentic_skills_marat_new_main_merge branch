from __future__ import annotations

import argparse
import json
import re
from collections import Counter, defaultdict
from pathlib import Path
from typing import Any


ROOT = Path(__file__).resolve().parents[2]
TARGET_JSON = ROOT / "localization/tracked_workspace/mz-fr.test.cbap.ru_Volga_tr.json"
OLD_JSON = ROOT / "cmw-platform-workspace/mz-fr.test.cbap.ru_Volga_tr_old.json"
TM_JSON = ROOT / "localization/translation_memory.json"
SEED_JSON = ROOT / "localization/csv_seed_dictionary.json"
VOLGA_MODEL = ROOT / "Volga (21)/Volga"
OUT_DIR = ROOT / "localization/aliasrenamed_batches"
JSONL_FILE = OUT_DIR / "20260518_aliasrenamed_first500.jsonl"
TABLE_FILE = OUT_DIR / "20260518_aliasrenamed_first100_table.md"
VALIDATION_FILE = OUT_DIR / "20260518_aliasrenamed_first500_validation.json"

ALIAS_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")
CYRILLIC_RE = re.compile(r"[А-Яа-яЁё]")
HEX_SUFFIX_RE = re.compile(r"([A-Fa-f0-9]{4,})$")

COMMON_ALIASES = {
    "id": "ID",
    "api": "API",
    "qr": "QR",
    "sla": "SLA",
    "bpmn": "BPMN",
    "dwg": "DWG",
    "url": "URL",
    "html": "HTML",
    "pdf": "PDF",
    "xml": "XML",
    "json": "JSON",
    "excel": "Excel",
}

TRANSLIT_MAP = {
    "ApartmentOwners": "Residents",
    "Measurementdevices": "MeterDevices",
    "ПотребительСобственник": "OwnerConsumer",
    "Sotrudniki": "Staff",
    "Schetchiki": "Meters",
    "Zdaniya": "Buildings",
    "Pomescheniya": "Spaces",
    "Sobytiya": "WorkOrders",
    "Raboty": "WorkTasks",
    "Dogovory": "Contracts",
    "Oborudovanie": "Equipment",
    "Imuschestvo": "Assets",
    "Arendator": "Tenants",
    "Kontragenty": "Counterparties",
    "Tip": "Type",
    "Status": "Status",
    "Nazvanie": "Name",
    "Naimenovanie": "Name",
    "Opisanie": "Description",
    "Kod": "Code",
    "Nomer": "Number",
    "Data": "Date",
    "Datavozniknoveniya": "ReportedDate",
    "Otvetstvennyy": "Assignee",
    "Ispolnitel": "Assignee",
}

STOP_WORDS = {
    "a",
    "an",
    "and",
    "by",
    "for",
    "from",
    "in",
    "of",
    "on",
    "or",
    "the",
    "to",
    "with",
}


def load_json(path: Path) -> Any:
    with path.open(encoding="utf-8-sig") as f:
        return json.load(f)


def write_json(path: Path, data: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def is_valid_alias(value: str) -> bool:
    return (
        bool(value)
        and len(value) <= 40
        and ALIAS_RE.fullmatch(value) is not None
        and CYRILLIC_RE.search(value) is None
        and not value.endswith("_calc")
        and not value.endswith("_sv")
    )


def strip_suffix(value: str) -> str:
    return re.sub(r"_(?:calc|sv)$", "", value or "")


def clean_alias_text(value: str) -> str:
    value = strip_suffix(value).strip()
    value = value.replace("&", " and ")
    value = re.sub(r"\([^)]*\)", " ", value)
    value = re.sub(r"[^0-9A-Za-z]+", " ", value)
    words = [w for w in value.split() if w.lower() not in STOP_WORDS]
    if not words:
        return ""

    parts: list[str] = []
    for word in words:
        low = word.lower()
        if low in COMMON_ALIASES:
            parts.append(COMMON_ALIASES[low])
        elif word.isupper() and len(word) <= 5:
            parts.append(word)
        else:
            parts.append(word[:1].upper() + word[1:])

    alias = "".join(parts)
    if alias and alias[0].isdigit():
        alias = f"Value{alias}"
    return alias[:40]


def first_display_name(entry: dict[str, Any], renamed: bool = False) -> str:
    key = "displayNameRenamed" if renamed else "displayNameOriginal"
    names = entry.get("displayNames")
    if isinstance(names, list):
        for item in names:
            value = item.get(key) or item.get("displayNameOriginal") or ""
            if value:
                return value
    return entry.get(key, "")


def load_old_aliases() -> dict[str, dict[str, str]]:
    old_by_alias: dict[str, dict[str, str]] = {}
    if not OLD_JSON.exists():
        return old_by_alias
    for entry in load_json(OLD_JSON):
        original = entry.get("aliasOriginal", "")
        renamed = strip_suffix(entry.get("aliasRenamed", ""))
        display = entry.get("displayNameRenamed", "")
        old_by_alias[original] = {"alias": renamed, "display": display}
    return old_by_alias


def load_seed_aliases() -> dict[tuple[str, str], str]:
    seed: dict[tuple[str, str], str] = {}
    if not SEED_JSON.exists():
        return seed
    for value in load_json(SEED_JSON).values():
        template = value.get("template", "")
        ru_alias = value.get("ru_alias", "")
        en_alias = clean_alias_text(value.get("en_alias", ""))
        if template and ru_alias and is_valid_alias(en_alias):
            seed[(template, ru_alias)] = en_alias
    return seed


def load_translation_memory() -> dict[str, str]:
    if not TM_JSON.exists():
        return {}
    data = load_json(TM_JSON)
    return {str(k): str(v) for k, v in data.items() if isinstance(v, str)}


def load_model_names() -> dict[str, str]:
    names: dict[str, str] = {}
    if not VOLGA_MODEL.exists():
        return names
    for path in VOLGA_MODEL.rglob("*.json"):
        try:
            data = load_json(path)
        except (OSError, json.JSONDecodeError):
            continue
        alias = data.get("GlobalAlias", {}).get("Alias")
        name = data.get("Name", "")
        if alias and name and not CYRILLIC_RE.search(name):
            names.setdefault(alias, name)
    return names


def propose_alias(
    entry: dict[str, Any],
    old_aliases: dict[str, dict[str, str]],
    seed_aliases: dict[tuple[str, str], str],
    tm: dict[str, str],
    model_names: dict[str, str],
) -> tuple[str, str, str]:
    original = entry.get("aliasOriginal", "")
    parent = entry.get("parent_template", "")
    display = first_display_name(entry)

    if entry.get("aliasLocked"):
        if is_valid_alias(original):
            return original, "locked", "aliasLocked=true; keep original system name"
        return clean_alias_text(original), "locked_sanitized", "aliasLocked=true; original was invalid"

    old = old_aliases.get(original, {}).get("alias", "")
    if is_valid_alias(old):
        return old, "old", "reused old aliasRenamed after suffix cleanup"

    seed = seed_aliases.get((parent, original))
    if is_valid_alias(seed):
        return seed, "seed", "exact seed dictionary match"

    model_name = model_names.get(original, "")
    model_alias = clean_alias_text(model_name)
    if is_valid_alias(model_alias):
        return model_alias, "model_display", "derived from localized Volga (21) display name"

    tm_value = tm.get(display, "")
    tm_alias = clean_alias_text(tm_value)
    if is_valid_alias(tm_alias):
        return tm_alias, "tm_display", "derived from translation memory display match"

    mapped = TRANSLIT_MAP.get(original, "")
    if is_valid_alias(mapped):
        return mapped, "rule", "known Volga terminology rule"

    fallback = clean_alias_text(original)
    if is_valid_alias(fallback):
        return fallback, "fallback", "sanitized original alias; needs review"

    return "NeedsReview", "manual", "no safe proposal"


def extract(limit: int, offset: int) -> list[dict[str, Any]]:
    target = load_json(TARGET_JSON)
    old_aliases = load_old_aliases()
    seed_aliases = load_seed_aliases()
    tm = load_translation_memory()
    model_names = load_model_names()

    rows: list[dict[str, Any]] = []
    for index, entry in enumerate(target):
        if entry.get("aliasRenamed"):
            continue
        if index < offset:
            continue
        proposed, source, note = propose_alias(entry, old_aliases, seed_aliases, tm, model_names)
        row = {
            "index": index,
            "type": entry.get("type", ""),
            "aliasLocked": bool(entry.get("aliasLocked")),
            "parent_template": entry.get("parent_template", ""),
            "aliasOriginal": entry.get("aliasOriginal", ""),
            "aliasRenamed": proposed,
            "displayNameOriginal": first_display_name(entry),
            "displayNameRenamedHint": (
                old_aliases.get(entry.get("aliasOriginal", ""), {}).get("display")
                or tm.get(first_display_name(entry), "")
                or model_names.get(entry.get("aliasOriginal", ""), "")
            ),
            "source": source,
            "note": note,
        }
        rows.append(row)
        if len(rows) >= limit:
            break

    OUT_DIR.mkdir(parents=True, exist_ok=True)
    with JSONL_FILE.open("w", encoding="utf-8", newline="\n") as f:
        for row in rows:
            f.write(json.dumps(row, ensure_ascii=False) + "\n")
    return rows


def load_jsonl(path: Path = JSONL_FILE) -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    with path.open(encoding="utf-8") as f:
        for line in f:
            if line.strip():
                rows.append(json.loads(line))
    return rows


def validate(rows: list[dict[str, Any]]) -> dict[str, Any]:
    issues: list[dict[str, Any]] = []
    aliases_by_scope: defaultdict[tuple[str, str, str], list[int]] = defaultdict(list)

    for row in rows:
        alias = row.get("aliasRenamed", "")
        if not is_valid_alias(alias):
            issues.append({
                "index": row["index"],
                "aliasOriginal": row["aliasOriginal"],
                "aliasRenamed": alias,
                "issue": "invalid_alias",
            })
        scope = (row.get("type", ""), row.get("parent_template", ""), alias)
        aliases_by_scope[scope].append(row["index"])

    for (row_type, parent, alias), indexes in aliases_by_scope.items():
        if alias and len(indexes) > 1:
            issues.append({
                "indexes": indexes,
                "type": row_type,
                "parent_template": parent,
                "aliasRenamed": alias,
                "issue": "duplicate_in_type_parent_scope",
            })

    return {
        "total": len(rows),
        "valid": not issues,
        "issue_count": len(issues),
        "issues": issues,
        "source_counts": dict(Counter(row.get("source", "") for row in rows)),
    }


def table(limit: int) -> str:
    rows = load_jsonl()[:limit]
    lines = [
        "# AliasRenamed Batch Review",
        "",
        "| Idx | L | Type | AO | Original Alias | RU Display | New Alias | Source | Notes |",
        "|-----|---|------|----|----------------|------------|-----------|--------|-------|",
    ]
    for row in rows:
        locked = "T" if row["aliasLocked"] else "F"
        ao = row.get("parent_template", "")
        notes = row.get("note", "")
        lines.append(
            "| {index} | {locked} | {type} | {ao} | `{orig}` | {display} | `{new}` | {source} | {notes} |".format(
                index=row["index"],
                locked=locked,
                type=row["type"],
                ao=ao.replace("|", "\\|"),
                orig=row["aliasOriginal"].replace("|", "\\|"),
                display=row["displayNameOriginal"].replace("|", "\\|"),
                new=row["aliasRenamed"].replace("|", "\\|"),
                source=row["source"],
                notes=notes.replace("|", "\\|"),
            )
        )
    TABLE_FILE.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return "\n".join(lines)


def apply_rows() -> int:
    rows = load_jsonl()
    report = validate(rows)
    if not report["valid"]:
        write_json(VALIDATION_FILE, report)
        raise SystemExit(f"Refusing to apply: {report['issue_count']} validation issues")

    target = load_json(TARGET_JSON)
    for row in rows:
        target[row["index"]]["aliasRenamed"] = row["aliasRenamed"]
    write_json(TARGET_JSON, target)
    return len(rows)


def main() -> int:
    parser = argparse.ArgumentParser()
    sub = parser.add_subparsers(dest="command", required=True)

    extract_cmd = sub.add_parser("extract")
    extract_cmd.add_argument("--limit", type=int, default=500)
    extract_cmd.add_argument("--offset", type=int, default=0)
    extract_cmd.add_argument("--dry-run", action="store_true")

    table_cmd = sub.add_parser("table")
    table_cmd.add_argument("--limit", type=int, default=100)

    sub.add_parser("validate")
    sub.add_parser("apply")

    args = parser.parse_args()

    if args.command == "extract":
        rows = extract(args.limit, args.offset)
        report = validate(rows)
        write_json(VALIDATION_FILE, report)
        print(f"Extracted {len(rows)} rows to {JSONL_FILE}")
        print(f"Validation issues: {report['issue_count']}")
        print(f"Sources: {report['source_counts']}")
        if args.dry_run:
            print("Dry run: target JSON was not changed")
        return 0 if report["valid"] else 2

    if args.command == "table":
        text = table(args.limit)
        print(text)
        print(f"\nSaved table to {TABLE_FILE}")
        return 0

    if args.command == "validate":
        report = validate(load_jsonl())
        write_json(VALIDATION_FILE, report)
        print(json.dumps(report, ensure_ascii=False, indent=2))
        return 0 if report["valid"] else 2

    if args.command == "apply":
        count = apply_rows()
        print(f"Applied {count} AliasRenamed values to {TARGET_JSON}")
        return 0

    return 1


if __name__ == "__main__":
    raise SystemExit(main())

