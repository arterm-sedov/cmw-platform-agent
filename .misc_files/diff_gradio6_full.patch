From 524d03307a4abbd7cd99f0f5ab2415f08dfdb8e5 Mon Sep 17 00:00:00 2001
From: arterm-sedov <artem.sedov@comindware.com>
Date: Sat, 24 Jan 2026 16:48:27 +0300
Subject: [PATCH 03/29] Refactor message handling in working history to improve
 type safety

- Updated logic to ensure that only dictionary-type messages are processed when checking for recent tool messages, enhancing robustness and preventing potential errors from unexpected data types.
---
 agent_ng/app_ng_modular.py | 12 +++++-------
 1 file changed, 5 insertions(+), 7 deletions(-)

diff --git a/agent_ng/app_ng_modular.py b/agent_ng/app_ng_modular.py
index d661800..34f576a 100644
--- a/agent_ng/app_ng_modular.py
+++ b/agent_ng/app_ng_modular.py
@@ -827,13 +827,11 @@ async def stream_chat_with_agent(
                             for i in range(
                                 max(0, len(working_history) - 3), len(working_history)
                             ):
-                                if (
-                                    i >= 0
-                                    and working_history[i]
-                                    and working_history[i]
-                                    .get("metadata", {})
-                                    .get("title")
-                                ):
+                                msg = working_history[i]
+                                if not isinstance(msg, dict):
+                                    continue
+                                metadata = msg.get("metadata") or {}
+                                if isinstance(metadata, dict) and metadata.get("title"):
                                     has_recent_tool_messages = True
                                     break
 

From 86681084b19d8ef6df051d19c25dad08d647266f Mon Sep 17 00:00:00 2001
